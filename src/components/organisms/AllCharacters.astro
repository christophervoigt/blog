---
import { getCollection } from 'astro:content'

import CharacterTeaser from '../molecules/CharacterTeaser.astro'

const characters = (await getCollection('dnd')).sort((a, b) => {
	if (a.data.name < b.data.name) {
		return 1
	} else if (a.data.name > b.data.name) {
		return -1
	} else {
		return 0
	}
})
---

<div class="teasers">
	{characters.map((character) => <CharacterTeaser {...character} headlineLevel="h2" />)}
</div>
