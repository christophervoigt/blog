---
import './CharacterSheet.css'

interface Props {
	name: string
	class: string
	subclass?: string
	level: number
	hit_points: number
	armor_class: number
	speed: string
	proficiency_bonus: number
	initiative: number
	abilities: Record<string, number>
	saving_throws: Record<string, { base_value: number; proficiency?: boolean }>
	senses?: {
		passive_perception?: number
		darkvision?: string
		blindsight?: string
	}
	defenses?: Record<string, string[]>
	training: Record<string, string[]>
	skills: Record<string, { base_value: number; proficiency?: boolean; disadvantage?: boolean }>
	background?: {
		title: string
		feature: string
		description: string
	}
	characteristics?: {
		race?: string
		alignment?: string
		gender?: string
		size?: string
		eyes?: string
		hair?: string
		personality_traits?: string
		ideals?: string
		bonds?: string
		flaws?: string
	}
	actions?: {
		note?: string
		attacks: { name: string; meta?: string; to_hit?: string; damage?: string }[]
	}
	bonus_actions?: { type?: 'Bonus' | 'Reaction'; name: string; text: string }[]
	inventory?: { group: string; items: { name: string; note?: string }[] }[]
	coins?: { gold?: number; silver?: number; copper?: number }
	resources?: { name: string; reset?: string; max: number }[]
	features?: { source?: string; name: string; text: string }[]
	feats?: { level?: string; name: string; text: string }[]
}

const {
	name,
	class: charClass,
	subclass,
	level,
	hit_points,
	armor_class,
	speed,
	proficiency_bonus,
	initiative,
	abilities,
	saving_throws,
	senses,
	defenses,
	training,
	skills,
	background,
	characteristics,
	actions,
	bonus_actions,
	inventory,
	coins,
	resources,
	features,
	feats,
} = Astro.props

function modifier(score: number) {
	const mod = Math.floor((score - 10) / 2)
	return mod >= 0 ? `+${mod}` : `${mod}`
}

function formatSkillName(key: string) {
	return key
		.split('_')
		.map((word) => word.charAt(0).toUpperCase() + word.slice(1))
		.join(' ')
}

function formatModifier(value: number) {
	return value >= 0 ? `+${value}` : `${value}`
}

function slugify(value: string) {
	return value
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-|-$/g, '')
}

function formatSavingThrow(save: { base_value: number; proficiency?: boolean }) {
	const total = save.base_value + (save.proficiency ? proficiency_bonus : 0)
	return formatModifier(total)
}

function skillModifier(skill: { base_value: number; proficiency?: boolean }) {
	const total = skill.base_value + (skill.proficiency ? proficiency_bonus : 0)
	return total >= 0 ? `+${total}` : `${total}`
}

const abilityOrder = ['strength', 'dexterity', 'constitution', 'intelligence', 'wisdom', 'charisma']
const abilityAbbr: Record<string, string> = {
	strength: 'STR',
	dexterity: 'DEX',
	constitution: 'CON',
	intelligence: 'INT',
	wisdom: 'WIS',
	charisma: 'CHA',
}

const classLine = [subclass, charClass].filter(Boolean).join(' ')
const characterSubtitle = [`Level ${level}`, characteristics?.race, classLine].filter(Boolean).join(' ')

const hasNotes = Astro.slots.has('notes')

const storageKey = `cs-state:${slugify(name)}`
---

<div class="character-sheet" data-cs-key={storageKey}>
	<!-- Header -->
	<div class="header -highlight">
		<div class="header-id">
			<h1 class="name">{name}</h1>
			<p class="subtitle">{characterSubtitle}</p>
		</div>

		<div class="hp" data-cs-hp-max={hit_points}>
			<span class="hp-label">Hit Points</span>
			<p class="hp-values">
				<span class="hp-current" data-cs-hp="cur">{hit_points}</span>
				<span class="hp-maximum">/ <span data-cs-hp="max">{hit_points}</span></span>
				<span class="hp-temporary" data-cs-hp="temp" hidden>+<span data-cs-hp="temp-val">0</span> temp</span>
			</p>
			<input
				type="range"
				class="hp-range"
				data-cs-hp="range"
				data-state="healthy"
				min="0"
				max={hit_points}
				value={hit_points}
				style="--hp-pct: 100%;"
				aria-label="Current hit points"
			/>
			<div class="hp-controls">
				<div class="hp-group">
					<button type="button" class="hp-button -damage" data-cs-hp-btn="damage" aria-label="Take 1 damage">−</button>
					<span class="hp-group-label">HP</span>
					<button type="button" class="hp-button -heal" data-cs-hp-btn="heal" aria-label="Heal 1 hit point">+</button>
				</div>
				<div class="hp-group">
					<button type="button" class="hp-button -temporary" data-cs-hp-btn="temp-down" aria-label="Decrease temporary hit points">−</button>
					<span class="hp-group-label">Temp</span>
					<button type="button" class="hp-button -temporary" data-cs-hp-btn="temp-up" aria-label="Increase temporary hit points">+</button>
				</div>
			</div>
		</div>

		<div class="rests">
			<button type="button" class="rest" data-cs-rest="short rest">Short Rest</button>
			<button type="button" class="rest" data-cs-rest="long rest">Long Rest</button>
		</div>
	</div>

	<!-- Core Stats Bar -->
	<div class="stats">
		<div class="stat">
			<span class="stat-value">{armor_class}</span>
			<span class="stat-label">Armor Class</span>
		</div>
		<div class="stat">
			<span class="stat-value">{speed}</span>
			<span class="stat-label">Speed</span>
		</div>
		<div class="stat">
			<span class="stat-value">{formatModifier(initiative)}</span>
			<span class="stat-label">Initiative</span>
		</div>
		<div class="stat">
			<span class="stat-value">+{proficiency_bonus}</span>
			<span class="stat-label">Proficiency</span>
		</div>
	</div>

	<!-- Body -->
	<div class="body">
		<!-- Left column -->
		<div class="column -left">
			<!-- Abilities -->
			<div class="abilities-section">
				<h2 class="section-title">Abilities</h2>
				<div class="abilities">
					{
						abilityOrder.map((key) => (
							<div class="ability">
								<span class="ability-modifier">{modifier(abilities[key])}</span>
								<span class="ability-name">{abilityAbbr[key]}</span>
							</div>
						))
					}
				</div>
			</div>

			<!-- Saving Throws -->
			<section class="saves">
				<h2 class="section-title">Saving Throws</h2>
				<ul class="list">
					{
						abilityOrder.map((key) => {
							const save = saving_throws[key]
							const proficient = save.proficiency

							return (
								<li class:list={['list-row', { 'proficient -highlight': proficient }]}>
									<span class="list-label">
										{proficient && <span class="sr-only">Proficient in </span>}
										{formatSkillName(key)}
									</span>
									<span class="list-value">{formatSavingThrow(save)}</span>
								</li>
							)
						})
					}
				</ul>
			</section>

			<!-- Skills -->
			<section class="skills">
				<h2 class="section-title">Skills</h2>
				<ul class="list">
					{
						Object.entries(skills).map(([key, skill]) => {
							const total = skillModifier(skill)
							const proficient = skill.proficiency
							const disadvantaged = skill.disadvantage

							return (
								<li
									class:list={['list-row', { 'disadvantage -highlight': disadvantaged, 'proficient -highlight': proficient }]}
								>
									<span class="list-label">
										{proficient && <span class="sr-only">Proficient in </span>}
										{disadvantaged && <span class="sr-only">Disadvantaged in </span>}
										{formatSkillName(key)}
									</span>
									<span class="list-value">{total}</span>
								</li>
							)
						})
					}
				</ul>
			</section>

			<!-- Senses -->
			{
				senses && (
					<section class="senses-section">
						<h2 class="section-title">Senses</h2>
						<ul class="senses">
							{senses.passive_perception !== undefined && (
								<li class="sense">
									<p class="sense-value">{senses.passive_perception}</p>
									<p class="sense-label">Passive Perception</p>
								</li>
							)}
							{senses.darkvision && (
								<li class="sense">
									<p class="sense-value">{senses.darkvision}</p>
									<p class="sense-label">Darkvision</p>
								</li>
							)}
							{senses.blindsight && (
								<li class="sense">
									<p class="sense-value">{senses.blindsight}</p>
									<p class="sense-label">Blindsight</p>
								</li>
							)}
						</ul>
					</section>
				)
			}

			<!-- Defenses -->
			{
				defenses && Object.entries(defenses).some(([, v]) => v.length > 0) && (
					<section class="defenses-section">
						<h2 class="section-title">Defenses</h2>
						{Object.entries(defenses)
							.filter(([, items]) => items.length > 0)
							.map(([category, items]) => (
								<div class="defenses-group">
									<h3 class="defenses-label">{formatSkillName(category)}</h3>
									<ul class="tags">
										{items.map((item) => (
											<li class="chip">{item}</li>
										))}
									</ul>
								</div>
							))}
					</section>
				)
			}

			<!-- Training / Proficiencies -->
			<section class="proficiencies">
				<h2 class="section-title">Proficiencies</h2>
				{
					Object.entries(training).map(([category, items]) => (
						<div class="training-group">
							<h3 class="training-label">{formatSkillName(category)}</h3>
							<ul class="tags">
								{items.map((item) => (
									<li class="chip">{item}</li>
								))}
							</ul>
						</div>
					))
				}
			</section>
		</div>

		<!-- Middle column -->
		<div class="column -main">
			<!-- Actions / Attacks -->
			{
				actions && (
					<section class="actions">
						<h2 class="section-title">Actions</h2>
						{actions.note && <p class="note">{actions.note}</p>}
						<div class="attacks">
							<p class="attacks-column-head">Weapon</p>
							<p class="attacks-column-head -center">To Hit</p>
							<p class="attacks-column-head -center">Damage</p>
							{actions.attacks.map(({ name, meta, to_hit, damage }) => (
								<Fragment>
									<div class="attack">
										<p class="attack-name">{name}</p>
										{meta && <p class="attack-meta">{meta}</p>}
									</div>

									<p class="chip -stat -to-hit">{to_hit}</p>
									<p class="chip -stat">{damage}</p>
								</Fragment>
							))}
						</div>
					</section>
				)
			}

			<!-- Bonus Actions & Reactions -->
			{
				bonus_actions && bonus_actions.length > 0 && (
					<section class="bonus-actions">
						<h2 class="section-title">Bonus Actions & Reactions</h2>
						<ul class="bonus-list">
							{bonus_actions.map((action) => (
								<li class="bonus">
									<div class="bonus-head">
										<p class:list={['chip -badge', { '-reaction': action.type === 'Reaction' }]}>{action.type ?? 'Bonus'}</p>
										<p class="bonus-name">{action.name}</p>
									</div>
									<p class="bonus-text">{action.text}</p>
								</li>
							))}
						</ul>
					</section>
				)
			}
			<!-- Class & Racial Features -->
			{
				features && features.length > 0 && (
					<section class="features">
						<h2 class="section-title">Class & Racial Features</h2>
						<ul class="feature-list">
							{features.map((feature) => (
								<li class="feature">
									<div class="feature-head">
										{feature.source && (
											<p
												class:list={[
													'chip -badge',
													{ '-subclass': feature.source === subclass },
													{ '-race': feature.source === characteristics?.race },
												]}
											>
												{feature.source}
											</p>
										)}
										<p class="feature-name">{feature.name}</p>
									</div>
									<p class="feature-text">{feature.text}</p>
								</li>
							))}
						</ul>
					</section>
				)
			}

			<!-- Feats -->
			{
				feats && feats.length > 0 && (
					<section class="feats">
						<h2 class="section-title">Feats</h2>
						<ul class="feat-list">
							{feats.map((feat) => (
								<li class="feat">
									<div class="feat-head">
										{feat.level && <p class="chip -badge -solid">{feat.level}</p>}
										<p class="feat-name">{feat.name}</p>
									</div>
									<p class="feat-text">{feat.text}</p>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</div>

		<!-- Right column -->
		<div class="column -right">
			<!-- Death Saves -->
			<section class="death-saves">
				<h2 class="section-title">Death Saves</h2>

				<div class="death-saves-wrapper">
					<div class="death-save">
						<p class="death-save-label">
							Successes <span class="sr-only" data-cs-count="deathS" data-cs-count-label="marked">0 of 3 marked</span>
						</p>
						<div class="pips">
							{
								Array.from({ length: 3 }).map((_, i) => (
									<button
										type="button"
										class="pip -success"
										data-cs-pip
										data-cs-group="deathS"
										data-cs-index={i}
										aria-pressed="false"
										aria-label={`Death save success ${i + 1}`}
									/>
								))
							}
						</div>
					</div>

					<div class="death-save">
						<p class="death-save-label">
							Failures <span class="sr-only" data-cs-count="deathF" data-cs-count-label="marked">0 of 3 marked</span>
						</p>
						<div class="pips -failure">
							{
								Array.from({ length: 3 }).map((_, i) => (
									<button
										type="button"
										class="pip"
										data-cs-pip
										data-cs-group="deathF"
										data-cs-index={i}
										aria-pressed="false"
										aria-label={`Death save failure ${i + 1}`}
									/>
								))
							}
						</div>
					</div>
				</div>
			</section>

			<!-- Resources -->
			{
				resources && resources.length > 0 && (
					<section class="resources">
						<h2 class="section-title">Resources</h2>
						<div class="resource-grid">
							<p class="resource-column-head">Resource</p>
							<p class="resource-column-head -right">Uses</p>
							{resources.map((resource) => {
								const resGroup = `res-${slugify(resource.name)}`
								return (
									<Fragment>
										<div class="resource">
											<p class="resource-name">
												{resource.name}
												<span class="sr-only" data-cs-count={resGroup} data-cs-count-label="used">
													- 0 of {resource.max} used
												</span>
											</p>
											{resource.reset && <p class="resource-reset">{resource.reset}</p>}
										</div>

										<div class="pips -resource">
											{Array.from({ length: resource.max }).map((_, i) => (
												<button
													type="button"
													class="pip"
													data-cs-pip
													data-cs-group={resGroup}
													data-cs-index={i}
													data-cs-reset={resource.reset}
													aria-pressed="false"
													aria-label={`${resource.name} use ${i + 1}`}
												/>
											))}
										</div>
									</Fragment>
								)
							})}
						</div>
					</section>
				)
			}

			<!-- Inventory -->
			{
				(inventory || coins) && (
					<section class="inventory">
						<h2 class="section-title">Inventory</h2>
						{inventory?.map((group) => (
							<div class="inventory-group">
								<h3 class="inventory-label">{group.group}</h3>
								<ul class="inventory-list">
									{group.items.map((item) => (
										<li class="inventory-entry">
											<p class="inventory-name">{item.name}</p>
											{item.note && <p class="inventory-note">{item.note}</p>}
										</li>
									))}
								</ul>
							</div>
						))}
						{coins && (
							<div class="coins">
								{coins.gold !== undefined && (
									<div class="coin -gold">
										<p class="coin-value">{coins.gold}</p>
										<p class="coin-label">Gold</p>
									</div>
								)}
								{coins.silver !== undefined && (
									<div class="coin -silver">
										<p class="coin-value">{coins.silver}</p>
										<p class="coin-label">Silver</p>
									</div>
								)}
								{coins.copper !== undefined && (
									<div class="coin -copper">
										<p class="coin-value">{coins.copper}</p>
										<p class="coin-label">Copper</p>
									</div>
								)}
							</div>
						)}
					</section>
				)
			}

			<!-- Background -->
			{
				background && (
					<section class="background">
						<h2 class="section-title">Background</h2>
						<div class="background-head">
							<p class="chip -badge">{background.title}</p>
							<p class="background-name">{background.feature}</p>
						</div>
						<p class="background-text">{background.description}</p>
					</section>
				)
			}

			<!-- Characteristics -->
			{
				characteristics && (
					<section class="characteristics">
						<h2 class="section-title">Characteristics</h2>

						<div class="attributes">
							{characteristics.alignment && (
								<div class="attribute">
									<p class="attribute-label">Alignment</p>
									<p class="chip">{characteristics.alignment}</p>
								</div>
							)}
							{characteristics.race && (
								<div class="attribute">
									<p class="attribute-label">Race</p>
									<p class="chip">{characteristics.race}</p>
								</div>
							)}
							{characteristics.gender && (
								<div class="attribute">
									<p class="attribute-label">Gender</p>
									<p class="chip">{characteristics.gender}</p>
								</div>
							)}
							{characteristics.size && (
								<div class="attribute">
									<p class="attribute-label">Size</p>
									<p class="chip">{characteristics.size}</p>
								</div>
							)}
							{characteristics.eyes && (
								<div class="attribute">
									<p class="attribute-label">Eyes</p>
									<p class="chip">{characteristics.eyes}</p>
								</div>
							)}
							{characteristics.hair && (
								<div class="attribute">
									<p class="attribute-label">Hair</p>
									<p class="chip">{characteristics.hair}</p>
								</div>
							)}
						</div>

						<div class="traits-grid">
							{characteristics.personality_traits && (
								<div class="trait">
									<p class="trait-label">Personality Traits</p>
									<p class="trait-value">{characteristics.personality_traits}</p>
								</div>
							)}
							{characteristics.ideals && (
								<div class="trait">
									<p class="trait-label">Ideals</p>
									<p class="trait-value">{characteristics.ideals}</p>
								</div>
							)}
							{characteristics.bonds && (
								<div class="trait">
									<p class="trait-label">Bonds</p>
									<p class="trait-value">{characteristics.bonds}</p>
								</div>
							)}
							{characteristics.flaws && (
								<div class="trait">
									<p class="trait-label">Flaws</p>
									<p class="trait-value">{characteristics.flaws}</p>
								</div>
							)}
						</div>
					</section>
				)
			}
		</div>
	</div>

	<!-- Notes from Markdown Content -->
	{
		hasNotes && (
			<div class="notes content">
				<slot name="notes" />
			</div>
		)
	}
</div>

<script>
	function initSheet(root) {
		const key = root.dataset.csKey
		const hpEl = root.querySelector('.hp')
		const max = hpEl ? Number(hpEl.dataset.csHpMax) || 0 : 0

		// Discover pip groups (and their sizes) from the server-rendered DOM.
		const pips = Array.from(root.querySelectorAll('[data-cs-pip]'))
		const groupMax = {}
		const groupReset = {}
		for (const pip of pips) {
			const g = pip.dataset.csGroup
			groupMax[g] = (groupMax[g] || 0) + 1
			// Normalise the reset key so rest matching is case-insensitive.
			if (pip.dataset.csReset) groupReset[g] = pip.dataset.csReset.trim().toLowerCase()
		}
		const isDeath = (g) => g === 'deathS' || g === 'deathF'

		// Default state mirrors the SSR baseline: full HP, whatever pips ship filled.
		const state = { max, hp: { cur: max, temp: 0 }, groups: {} }
		for (const g in groupMax) {
			state.groups[g] = pips.filter((p) => p.dataset.csGroup === g && p.classList.contains('-filled')).length
		}

		// Overlay any persisted state, clamped to the current maxima.
		try {
			const raw = key && localStorage.getItem(key)
			if (raw) {
				const saved = JSON.parse(raw)
				if (saved && saved.hp) {
					// If the sheet was saved at full HP and max has since grown
					// (e.g. a level-up), treat the character as still full rather
					// than showing phantom damage.
					const wasFull = typeof saved.max === 'number' && typeof saved.hp.cur === 'number' && saved.hp.cur >= saved.max
					if (wasFull) state.hp.cur = max
					else if (typeof saved.hp.cur === 'number') state.hp.cur = Math.max(0, Math.min(max, saved.hp.cur))
					if (typeof saved.hp.temp === 'number') state.hp.temp = Math.max(0, saved.hp.temp)
				}
				if (saved && saved.groups) {
					for (const g in groupMax) {
						const v = saved.groups[g]
						if (typeof v === 'number') state.groups[g] = Math.max(0, Math.min(groupMax[g], v))
					}
				}
			}
		} catch (e) {}

		function persist() {
			if (!key) return
			try {
				localStorage.setItem(key, JSON.stringify(state))
			} catch (e) {}
		}

		function render() {
			if (hpEl) {
				const { cur, temp } = state.hp
				const curEl = hpEl.querySelector('[data-cs-hp="cur"]')
				if (curEl) curEl.textContent = String(cur)
				const tempWrap = hpEl.querySelector('[data-cs-hp="temp"]')
				const tempVal = hpEl.querySelector('[data-cs-hp="temp-val"]')
				if (tempVal) tempVal.textContent = String(temp)
				if (tempWrap) tempWrap.hidden = temp <= 0
				const range = hpEl.querySelector('[data-cs-hp="range"]')
				if (range) {
					const pct = max > 0 ? Math.max(0, Math.min(100, Math.round((cur / max) * 100))) : 0
					range.max = String(max)
					range.value = String(cur)
					range.style.setProperty('--hp-pct', pct + '%')
					range.dataset.state = pct > 50 ? 'healthy' : pct > 25 ? 'wounded' : 'critical'
					range.setAttribute('aria-valuetext', `${cur} of ${max} hit points`)
				}
			}

			for (const pip of pips) {
				const filled = Number(pip.dataset.csIndex) < state.groups[pip.dataset.csGroup]
				pip.classList.toggle('-filled', filled)
				pip.setAttribute('aria-pressed', String(filled))
			}

			root.querySelectorAll('[data-cs-count]').forEach((el) => {
				const g = el.dataset.csCount
				const n = state.groups[g] || 0
				const m = groupMax[g] || 0
				el.textContent = el.dataset.csCountLabel === 'used' ? `- ${n} of ${m} used` : `${n} of ${m} marked`
			})
		}

		function setPip(g, i) {
			const cur = state.groups[g] || 0
			state.groups[g] = i + 1 === cur ? i : i + 1
		}

		function adjustHp(delta) {
			let { cur, temp } = state.hp
			if (delta < 0) {
				let d = -delta
				const absorbed = Math.min(temp, d)
				temp -= absorbed
				d -= absorbed
				cur = Math.max(0, cur - d)
			} else {
				cur = Math.min(max, cur + delta)
			}
			state.hp = { cur, temp }
		}

		// Resource pips track spent uses, so a rest clears them back to empty.
		function clearResources(resetType) {
			for (const g in groupMax) {
				if (isDeath(g)) continue
				if (resetType === null || groupReset[g] === resetType) state.groups[g] = 0
			}
		}

		function rest(kind) {
			if (kind === 'short rest') {
				clearResources('short rest')
			} else {
				clearResources(null)
				state.hp = { cur: max, temp: 0 }
				state.groups.deathS = 0
				state.groups.deathF = 0
			}
		}

		root.addEventListener('click', (event) => {
			const target = event.target
			const pip = target.closest('[data-cs-pip]')
			if (pip && root.contains(pip)) {
				setPip(pip.dataset.csGroup, Number(pip.dataset.csIndex))
				render()
				persist()
				return
			}
			const hpBtn = target.closest('[data-cs-hp-btn]')
			if (hpBtn) {
				const action = hpBtn.dataset.csHpBtn
				if (action === 'damage') adjustHp(-1)
				else if (action === 'heal') adjustHp(1)
				else if (action === 'temp-up') state.hp.temp += 1
				else if (action === 'temp-down') state.hp.temp = Math.max(0, state.hp.temp - 1)
				render()
				persist()
				return
			}
			const restBtn = target.closest('[data-cs-rest]')
			if (restBtn) {
				rest((restBtn.dataset.csRest || '').trim().toLowerCase())
				render()
				persist()
			}
		})

		// Dragging the range sets current HP directly (temp is unaffected).
		const range = hpEl && hpEl.querySelector('[data-cs-hp="range"]')
		if (range) {
			range.addEventListener('input', () => {
				state.hp.cur = Math.max(0, Math.min(max, parseInt(range.value, 10) || 0))
				render()
				persist()
			})
		}

		render()
	}

	function boot() {
		document.querySelectorAll('.character-sheet').forEach((el) => {
			if (el.dataset.csReady) return
			el.dataset.csReady = 'true'
			initSheet(el)
		})
	}

	boot()
	document.addEventListener('astro:page-load', boot)
</script>
