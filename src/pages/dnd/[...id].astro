---
import { getCollection, render } from 'astro:content'

import Page from '../../components/templates/Page.astro'
import CharacterSheet from '../../components/organisms/CharacterSheet/CharacterSheet.astro'

export async function getStaticPaths() {
	const characters = await getCollection('dnd')

	return characters.map((post) => {
		const id = post.id

		return {
			params: { id },
			props: { post },
		}
	})
}

const { post } = Astro.props
const { data } = post
const { name, class: charClass, subclass, level } = data

const { Content } = await render(post)
---

<Page title={name} description={`${name} — Level ${level} ${subclass ? subclass + ' ' : ''}${charClass}`}>
	<CharacterSheet {...data}>
		<Content />
	</CharacterSheet>
</Page>
